# Your iMessage phone number (must match what's signed into Messages)
MY_NUMBER=+1234567890

# Anthropic API key — get one at console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Only respond to messages from these numbers (comma-separated)
# Defaults to MY_NUMBER if not set
ALLOWED_SENDERS=+1234567890

# Brave Search API key — free tier at api.search.brave.com (2000 calls/month)
# Leave blank to disable web search
BRAVE_API_KEY=

# Google Calendar OAuth2 — run `bun run calendar:auth` to generate these
# Leave blank to disable calendar features
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
# Your calendar ID (usually your email address)
GOOGLE_CALENDAR_ID=primary

# Tuning (optional)
DEBUG=false
CONTEXT_WINDOW_MIN=30
CONTEXT_MAX_TURNS=10

# Debounce window in ms — messages arriving within this window are batched together
# 0 to disable batching (default: 45000 = 45 seconds)
DEBOUNCE_MS=45000
